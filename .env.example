# .env.example — Copy this to .env and fill in your values
# DermIQ Environment Variables

# ── Security ────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
DERMIQ_SECRET_KEY=dermiq-super-secret-change-in-prod-2025

# Token expiry in hours (default: 72 hours = 3 days)
TOKEN_EXPIRY_HOURS=72

# ── Database ────────────────────────────────────
# Path to SQLite database file (relative to project root)
# Leave blank to use default: dermiq.db in project root
DERMIQ_DB_PATH=dermiq.db

# ── Server ──────────────────────────────────────
# Port Flask runs on
PORT=5000
FLASK_ENV=development

# ── Ollama ──────────────────────────────────────
# Ollama runs locally — no API key needed
# Default: http://127.0.0.1:11434
OLLAMA_HOST=http://127.0.0.1:11434
